<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="pos_custom_product.CustomProductPopup">
        <Dialog title="'Producto personalizado'">
            <div class="p-3">
                <div class="mb-3">
                    <label>Descripción</label>
                    <input t-model="state.description" class="form-control"/>
                </div>

                <div class="mb-3">
                    <label>Precio de coste</label>
                    <input t-model="state.cost" class="form-control" type="number"/>
                </div>
            </div>

            <t t-set-slot="footer">
                <button class="btn btn-secondary" t-on-click="cancel">
                    Cancelar
                </button>
                <button class="btn btn-primary" t-on-click="confirm">
                    Confirmar
                </button>
            </t>
        </Dialog>
    </t>

</templates>