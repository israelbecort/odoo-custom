<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="pos_custom_product.AskCreateProductPopup">
        <Dialog title="'Producto no encontrado'">
            <div class="p-3">
                <p>No existe ningún producto con este código de barras:</p>
                <h4><t t-esc="props.barcode"/></h4>
                <p>¿Desea crear el producto?</p>
            </div>

            <t t-set-slot="footer">
                <button class="btn btn-secondary" t-on-click="no">No</button>
                <button class="btn btn-primary" t-on-click="yes">Sí, crear</button>
            </t>
        </Dialog>
    </t>

    <t t-name="pos_custom_product.CreateProductFromBarcodePopup">
        <Dialog title="'Crear producto'">
            <div class="p-3">

                <div class="mb-3">
                    <label>Código de barras</label>
                    <input class="form-control" t-att-value="props.barcode" disabled="disabled"/>
                </div>

                <div class="mb-3">
                    <label>Nombre</label>
                    <input class="form-control" t-model="state.name"/>
                </div>

                <div class="mb-3">
                    <label>Precio venta final</label>
                    <input class="form-control" type="number" step="0.01" t-model="state.finalPrice"/>
                </div>

                <div class="mb-3">
                    <label>Coste</label>
                    <input class="form-control" type="number" step="0.01" t-model="state.cost"/>
                </div>

                <div class="mb-3">
                    <label>Categoría TPV</label>
                    <select class="form-select" t-model="state.posCategoryId">
                        <option value="">Seleccione categoría</option>
                        <t t-foreach="props.categories" t-as="category" t-key="category.id">
                            <option t-att-value="category.id">
                                <t t-esc="category.name"/>
                            </option>
                        </t>
                    </select>
                </div>

                <div class="mb-3">
                    <label>Impuesto</label>
                    <select class="form-select" t-model="state.taxRate">
                        <option value="21">IVA 21%</option>
                        <option value="10">IVA 10%</option>
                        <option value="4">IVA 4%</option>
                    </select>
                </div>

            </div>

            <t t-set-slot="footer">
                <button class="btn btn-secondary" t-on-click="cancel">Cancelar</button>
                <button class="btn btn-primary" t-on-click="confirm">Crear producto</button>
            </t>
        </Dialog>
    </t>

</templates>