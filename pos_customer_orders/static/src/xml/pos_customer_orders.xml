<?xml version="1.0" encoding="UTF-8"?>
<templates id="template" xml:space="preserve">

    <t t-name="pos_customer_orders.CustomerOrderPopup">
        <Dialog title="'Nuevo encargo'">
            <div class="p-3">

                <div class="mb-3">
                    <label>Cliente</label>
                    <div class="d-flex gap-2 align-items-center">
                        <div class="form-control bg-light">
                            <t t-esc="state.partner?.name || 'Sin cliente'"/>
                        </div>
                        <button class="btn btn-secondary" t-on-click="changePartner">
                            Cambiar
                        </button>
                    </div>
                </div>

                <div class="mb-3">
                    <label>Productos del encargo</label>

                    <div class="border rounded p-2" style="max-height: 260px; overflow-y: auto;">
                        <t t-foreach="props.lines" t-as="line" t-key="line.uuid">
                            <div class="d-flex align-items-center gap-2 py-2 border-bottom">
                                <input type="checkbox"
                                       t-att-checked="state.selectedLineUuids[line.uuid]"
                                       t-on-change="() => this.toggleLine(line.uuid)"/>

                                <div class="flex-grow-1">
                                    <div class="fw-bold">
                                        <t t-esc="line.description"/>
                                    </div>
                                    <div class="text-muted small">
                                        Cantidad:
                                        <t t-esc="line.qty"/>
                                    </div>
                                </div>

                                <div class="fw-bold text-end">
                                    <t t-esc="line.price_subtotal_incl.toFixed(2)"/> €
                                </div>
                            </div>
                        </t>
                    </div>

                    <div class="mt-2 fw-bold text-end">
                        Total seleccionado:
                        <t t-esc="selectedTotal.toFixed(2)"/> €
                    </div>
                </div>

                <div class="mb-3">
                    <label>Anticipo pagado</label>
                    <div class="input-group" style="max-width: 200px;">
                        <input class="form-control text-end"
                               type="number"
                               step="0.01"
                               t-model="state.paidAmount"/>
                        <span class="input-group-text">€</span>
                    </div>
                </div>

                <div class="mb-3">
                    <label>Fecha prevista</label>
                    <input class="form-control"
                           type="date"
                           style="max-width: 200px;"
                           t-model="state.expectedDate"/>
                </div>

                <div class="mb-3">
                    <label>Nota opcional</label>
                    <textarea class="form-control" rows="3" t-model="state.note"/>
                </div>

            </div>

            <t t-set-slot="footer">
                <button class="btn btn-secondary" t-on-click="cancel">Cancelar</button>
                <button class="btn btn-primary" t-on-click="confirm">Crear encargo</button>
            </t>
        </Dialog>
    </t>

    <t t-inherit="point_of_sale.ControlButtons" t-inherit-mode="extension">
        <xpath expr="//SelectPartnerButton" position="after">
            <button t-if="!props.showRemainingButtons"
                    class="btn btn-secondary btn-lg border-0 text-truncate"
                    t-on-click="() => this.clickCustomerOrder()">
                <i class="fa fa-clipboard me-1"/>
                Encargo
            </button>
        </xpath>
    </t>

    <t t-name="pos_customer_orders.CustomerOrdersScreen">
        <div class="pos customer-orders-screen">
    
            <div class="top-content d-flex align-items-center gap-2 p-3 border-bottom">
                <button class="btn btn-secondary" t-on-click="back">
                    <i class="fa fa-arrow-left me-1"/>
                    Registrar
                </button>
    
                <h2 class="m-0 flex-grow-1">Encargos</h2>
    
                <select class="form-select w-auto"
                        t-model="state.filter"
                        t-on-change="loadOrders">
                    <option value="active">Activos</option>
                    <option value="draft">Pendientes</option>
                    <option value="received">Mercancía recibida</option>
                    <option value="done">Entregados</option>
                    <option value="cancel">Cancelados</option>
                    <option value="all">Todos</option>
                </select>
    
                <button class="btn btn-primary" t-on-click="loadOrders">
                    Actualizar
                </button>
            </div>
    
            <div class="p-3">
                <input class="form-control mb-3"
                       placeholder="Buscar encargo o cliente..."
                       t-model="state.search"/>
    
                <div class="list-group">
                    <t t-foreach="filteredOrders" t-as="order" t-key="order.id">
                        <div class="list-group-item d-flex align-items-center gap-3">
                            <div class="flex-grow-1">
                                <div class="fw-bold">
                                    <t t-esc="order.name"/>
                                </div>
    
                                <div class="text-muted">
                                    Cliente:
                                    <t t-esc="order.partner_id?.[1] || '-'"/>
                                </div>
    
                                <div class="text-muted">
                                    Fecha prevista:
                                    <t t-esc="order.expected_date || '-'"/>
                                </div>
    
                                <div>
                                    Total:
                                    <strong><t t-esc="order.total_amount.toFixed(2)"/> €</strong>
                                    · Pagado:
                                    <strong><t t-esc="order.paid_amount.toFixed(2)"/> €</strong>
                                    · Pendiente:
                                    <strong><t t-esc="order.pending_amount.toFixed(2)"/> €</strong>
                                </div>
                            </div>
    
                            <div class="text-end">
                                <div class="badge bg-secondary mb-2">
                                    <t t-esc="stateLabel(order.state)"/>
                                </div>
    
                                <div class="d-flex gap-2">
                                    <button t-if="order.state === 'draft'"
                                            class="btn btn-info"
                                            t-on-click="() => markReceived(order)">
                                        Mercancía recibida
                                    </button>
    
                                    <button t-if="order.state === 'received'"
                                            class="btn btn-success"
                                            t-on-click="() => markDone(order)">
                                        Entregado
                                    </button>
    
                                    <button t-if="order.state !== 'done' and order.state !== 'cancel'"
                                            class="btn btn-danger"
                                            t-on-click="() => cancelOrder(order)">
                                        Cancelar
                                    </button>
                                </div>
                            </div>
                        </div>
                    </t>
                </div>
            </div>
        </div>
    </t>

    <t t-inherit="point_of_sale.Navbar" t-inherit-mode="extension">
        <xpath expr="//button[contains(@class, 'orders-button')]" position="after">
            <button class="customer-orders-button btn btn-lg btn-light lh-lg"
                    t-att-class="{'active': this.pos.router.state.current === 'CustomerOrdersScreen'}"
                    t-on-click="() => this.pos.showScreen('CustomerOrdersScreen')">
                <t t-if="!ui.isSmall">
                    <span>Encargos</span>
                </t>
                <i t-else="" class="fa fa-fw fa-clipboard" t-att-class="{'fa-lg' : !ui.isSmall}"/>
            </button>
        </xpath>
    </t>

</templates>