<odoo>

    <!-- LISTA -->
    <record id="view_pos_customer_order_list" model="ir.ui.view">
        <field name="name">pos.customer.order.list</field>
        <field name="model">pos.customer.order</field>
        <field name="arch" type="xml">
            <list string="Encargos TPV">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="total_amount"/>
                <field name="paid_amount"/>
                <field name="pending_amount"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <!-- FORMULARIO -->
    <record id="view_pos_customer_order_form" model="ir.ui.view">
        <field name="name">pos.customer.order.form</field>
        <field name="model">pos.customer.order</field>
        <field name="arch" type="xml">
            <form string="Encargo">
                <sheet>

                    <group>
                        <field name="name"/>
                        <field name="partner_id"/>
                    </group>

                    <group>
                        <field name="note"/>
                    </group>

                    <group>
                        <field name="total_amount"/>
                        <field name="paid_amount"/>
                        <field name="pending_amount" readonly="1"/>
                    </group>

                    <group>
                        <field name="state"/>
                    </group>

                </sheet>
            </form>
        </field>
    </record>

    <!-- ACCIÓN -->
    <record id="action_pos_customer_order" model="ir.actions.act_window">
        <field name="name">Encargos TPV</field>
        <field name="res_model">pos.customer.order</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- MENÚ -->
    <menuitem id="menu_pos_customer_order"
              name="Encargos TPV"
              parent="point_of_sale.menu_point_root"
              action="action_pos_customer_order"
              sequence="90"/>

</odoo>