<odoo>

    <record id="view_pos_customer_order_list" model="ir.ui.view">
        <field name="name">pos.customer.order.list</field>
        <field name="model">pos.customer.order</field>
        <field name="arch" type="xml">
            <list string="Encargos TPV">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="expected_date"/>
                <field name="total_amount"/>
                <field name="paid_amount"/>
                <field name="pending_amount"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_pos_customer_order_form" model="ir.ui.view">
        <field name="name">pos.customer.order.form</field>
        <field name="model">pos.customer.order</field>
        <field name="arch" type="xml">
            <form string="Encargo">
                <header>
                    <button name="action_mark_received"
                            type="object"
                            string="Mercancía recibida"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <button name="action_mark_done"
                            type="object"
                            string="Marcar entregado"
                            class="btn-primary"
                            invisible="state != 'received'"/>

                    <button name="action_cancel"
                            type="object"
                            string="Cancelar"
                            invisible="state == 'cancel'"/>

                    <button name="action_back_to_draft"
                            type="object"
                            string="Volver a pendiente"
                            invisible="state == 'draft'"/>

                    <field name="state"
                        widget="statusbar"
                        statusbar_visible="draft,received,done,cancel"/>
                </header>
                <sheet>
                    <group>
                        <field name="name" readonly="1"/>
                        <field name="partner_id"/>
                        <field name="expected_date"/>
                        <field name="state"/>
                    </group>

                    <group>
                        <field name="total_amount"/>
                        <field name="paid_amount"/>
                        <field name="pending_amount" readonly="1"/>
                    </group>

                    <group>
                        <field name="note"/>
                    </group>

                    <notebook>
                        <page string="Líneas">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="description"/>
                                    <field name="qty"/>
                                    <field name="price_unit"/>
                                    <field name="price_subtotal_incl"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_pos_customer_order" model="ir.actions.act_window">
        <field name="name">Encargos TPV</field>
        <field name="res_model">pos.customer.order</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_pos_customer_order"
              name="Encargos TPV"
              parent="point_of_sale.menu_point_root"
              action="action_pos_customer_order"
              sequence="90"/>

</odoo>